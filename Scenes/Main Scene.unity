  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'This app is an augmented reality visualisation tool used for viewing satellites
    around the world based on the GPS location obtained from the current device.
    This app uses publicly available data from Celestrak. Live positions are based
    on real positions and projected/future satellites, and distributions are based
    on MOCAT and real satellite trends.

    Look around and tap on satellites in
    the list menu to see more information about them. Settings are available by tapping
    the gear icon.

    Future projections for satellites can be viewed by tapping
    the three lines icon above the list menu.

    This app was developed at The
    University of Manchester, using data from MIT and funded by EPSRC.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
